# Scraping: polite defaults for archive.org (1-8 parallel, 0.25-0.75 s jitter).
# Bumping concurrency or lowering the delay will get you rate-limited.
MAX_CONCURRENT_SCRAPES=8
ARCHIVE_REQUEST_TIMEOUT=60
ARCHIVE_RETRY_COUNT=3
SCRAPE_DELAY_MIN=0.25
SCRAPE_DELAY_MAX=0.75
SCRAPE_MAX_RETRIES=3

# Jobs
JOB_TTL_SECONDS=7200
MAX_ACTIVE_JOBS=10
SCAN_TIMEOUT_SECONDS=3600

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Database path (default is for Docker; override with a writable local
# path when running uvicorn outside of Docker)
# DATABASE_URL=./waytrace.db

# Adaptive rate limiter (per-source, used by collector + scraper)
RATE_LIMIT_INITIAL_DELAY=0.15
RATE_LIMIT_MIN_DELAY=0.1
RATE_LIMIT_MAX_DELAY=300.0
RATE_LIMIT_SPEEDUP_FACTOR=0.9
RATE_LIMIT_SPEEDUP_STREAK=10
RATE_LIMIT_BACKOFF_FACTOR=3.0
RATE_LIMIT_429_PAUSE=120.0
